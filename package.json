{
  "name": "cc-codex-sync",
  "version": "0.1.0",
  "description": "Bidirectional sync between Claude Code (CLAUDE.md + memory) and OpenAI Codex (AGENTS.md), so you can switch tools inside living projects.",
  "type": "module",
  "bin": {
    "ccsync": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "ccsync": "tsx src/cli.ts",
    "tui": "bun src/tui/main.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.tui.json",
    "test": "vitest run",
    "test:tui": "bun test test/tui.bun.test.tsx",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@opentui/core": "^0.4.1",
    "@opentui/react": "^0.4.1",
    "commander": "^12.1.0",
    "diff": "^7.0.0",
    "fast-glob": "^3.3.2",
    "gray-matter": "^4.0.3",
    "picocolors": "^1.1.1",
    "react": "^19.2.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
